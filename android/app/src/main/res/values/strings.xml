    <string name="guided_setup_question">Step 2: How should wake work?</string>
    <string name="guided_setup_question_detail">Pick one option. Then read the quick summary below and press Choose This Method.</string>
    <string name="guided_setup_choice_legacy_mobile_title">Old Phone / Tablet Relay</string>
    <string name="guided_setup_choice_legacy_mobile_detail">Use a spare Android phone or tablet left plugged in at home.</string>
    <string name="guided_setup_choice_media_client_title">Fire TV / Smart TV Relay</string>
    <string name="guided_setup_choice_media_client_detail">Use a streaming device or Android TV left on at home.</string>
    <string name="guided_setup_choice_voice_title">Smart Speaker Wake</string>
    <string name="guided_setup_choice_voice_detail">Use a smart speaker setup such as Alexa or Google Home.</string>
    <string name="guided_setup_choice_hardware_title">Smart Plug Power-On</string>
    <string name="guided_setup_choice_hardware_detail">Force the PC to boot by power-cycling a smart plug or similar hardware path.</string>
    <string name="guided_setup_choice_server_title">My Own Server</string>
    <string name="guided_setup_choice_server_detail">Use your own NAS, Raspberry Pi, router, server, or Docker host.</string>
    <string name="guided_setup_result_section">Recommendation</string>
    <string name="guided_setup_legacy_mobile_result_title">Use an Old Phone or Tablet at Home</string>
    <string name="guided_setup_legacy_mobile_result_detail">Install PowerBridge on a spare Android device and keep it plugged in at home. Your main phone will use that home device to help wake your PC when you are away.</string>
    <string name="guided_setup_legacy_mobile_result_status">Planned path. Best future remote option for most people once pairing is finished.</string>
    <string name="guided_setup_media_client_result_title">Use a Fire TV or Smart TV at Home</string>
    <string name="guided_setup_media_client_result_detail">Use a Fire TV Stick, Chromecast with Google TV, or Android TV device that stays on at home as the always-on wake helper.</string>
    <string name="guided_setup_media_client_result_status">Planned path. Good fit for homes that already keep a TV device powered on.</string>
    <string name="guided_setup_voice_result_title">Use a Smart Speaker Setup</string>
    <string name="guided_setup_voice_result_detail">Use an Alexa or Google Home style setup to trigger wake through your smart-home ecosystem instead of a spare phone.</string>
    <string name="guided_setup_voice_result_status">Research path. Not live in this build yet.</string>
    <string name="guided_setup_hardware_result_title">Use a Smart Plug or Hardware Power Path</string>
    <string name="guided_setup_hardware_result_detail">Use a smart plug or similar hardware route to force the PC to power on. This is a hardware workaround, not standard Wake-on-LAN.</string>
    <string name="guided_setup_hardware_result_status">Coming later. Use carefully because it depends on BIOS or hardware power settings.</string>
    <string name="guided_setup_server_result_title">Use Your Own Server</string>
    <string name="guided_setup_server_result_detail">Use your own always-on device, such as a Raspberry Pi, NAS, router, server, or Docker host, to send the wake packet inside your home network.</string>
    <string name="guided_setup_server_result_status">Live now for advanced users who already run their own server path.</string>
