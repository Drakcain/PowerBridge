<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="26dp"
        android:paddingEnd="24dp"
        android:paddingBottom="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/guided_setup_title"
            android:textColor="@color/cp_text_primary"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/guided_setup_subtitle"
            android:textColor="@color/cp_text_secondary"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/guided_setup_step_scan_title"
                    android:textColor="@color/cp_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/guided_setup_step_scan_detail"
                    android:textColor="@color/cp_text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/scanQrButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="@color/cp_action_wake_yellow"
                    android:text="@string/guided_setup_scan_button"
                    android:textAllCaps="false"
                    android:textColor="@color/cp_background"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />

                <TextView
                    android:id="@+id/importStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/guided_setup_scan_waiting_status"
                    android:textColor="@color/cp_warning"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/currentProfileText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/cp_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/currentMethodText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/cp_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/guided_setup_location_question"
                    android:textColor="@color/cp_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/guided_setup_location_detail"
                    android:textColor="@color/cp_text_secondary"
                    android:textSize="14sp" />

                <RadioGroup
                    android:id="@+id/locationOptionsGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/locationHomeOption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guided_setup_location_home_title"
                        android:textColor="@color/cp_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="30dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"
                        android:text="@string/guided_setup_location_home_detail"
                        android:textColor="@color/cp_text_secondary"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/locationAwayOption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guided_setup_location_away_title"
                        android:textColor="@color/cp_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="30dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"
                        android:text="@string/guided_setup_location_away_detail"
                        android:textColor="@color/cp_text_secondary"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/locationNotSureOption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guided_setup_location_not_sure_title"
                        android:textColor="@color/cp_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="30dp"
                        android:layout_marginTop="4dp"
                        android:text="@string/guided_setup_location_not_sure_detail"
                        android:textColor="@color/cp_text_secondary"
                        android:textSize="13sp" />

                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/remoteMethodsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/guided_setup_question"
                    android:textColor="@color/cp_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/guided_setup_question_detail"
                    android:textColor="@color/cp_text_secondary"
                    android:textSize="14sp" />

                <RadioGroup
                    android:id="@+id/methodOptionsGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/legacyMobileOption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guided_setup_choice_legacy_mobile_title"
                        android:textColor="@color/cp_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="30dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"
                        android:text="@string/guided_setup_choice_legacy_mobile_detail"
                        android:textColor="@color/cp_text_secondary"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/mediaClientOption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guided_setup_choice_media_client_title"
                        android:textColor="@color/cp_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="30dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"
                        android:text="@string/guided_setup_choice_media_client_detail"
                        android:textColor="@color/cp_text_secondary"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/voiceOption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guided_setup_choice_voice_title"
                        android:textColor="@color/cp_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="30dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"
                        android:text="@string/guided_setup_choice_voice_detail"
                        android:textColor="@color/cp_text_secondary"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/hardwareOption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guided_setup_choice_hardware_title"
                        android:textColor="@color/cp_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="30dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"
                        android:text="@string/guided_setup_choice_hardware_detail"
                        android:textColor="@color/cp_text_secondary"
                        android:textSize="13sp" />

                    <RadioButton
                        android:id="@+id/serverOption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guided_setup_choice_server_title"
                        android:textColor="@color/cp_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="30dp"
                        android:layout_marginTop="4dp"
                        android:text="@string/guided_setup_choice_server_detail"
                        android:textColor="@color/cp_text_secondary"
                        android:textSize="13sp" />

                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/guided_setup_result_section"
                    android:textAllCaps="true"
                    android:textColor="@color/cp_text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/recommendationTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/cp_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/recommendationDetailText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/cp_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/recommendationStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/cp_warning"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/primaryActionButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="@color/cp_action_wake_yellow"
                    android:text="@string/guided_setup_action_choose_method"
                    android:textAllCaps="false"
                    android:textColor="@color/cp_background"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/setupStatusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/guided_setup_final_section"
                    android:textAllCaps="true"
                    android:textColor="@color/cp_text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/finalStatusTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/cp_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/finalStatusStateText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/cp_warning"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/finalStatusNextStepText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/cp_text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/finalConfirmButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="@color/cp_action_wake_yellow"
                    android:text="@string/guided_setup_finish_confirm"
                    android:textAllCaps="false"
                    android:textColor="@color/cp_background"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
