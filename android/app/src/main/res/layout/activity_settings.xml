<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="22dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/settingsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/cp_text_primary"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_subtitle"
            android:textColor="@color/cp_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/profileCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_profile_section"
                    android:textColor="@color/cp_yellow"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/settings_profile_hint"
                    app:boxBackgroundColor="@color/cp_surface_raised"
                    app:boxStrokeColor="@color/cp_yellow"
                    app:endIconMode="dropdown_menu"
                    app:hintTextColor="@color/cp_text_muted">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/profileInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/cp_text_primary"
                        android:textColorHint="@color/cp_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/profileSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/cp_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/addProfileButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:maxLines="1"
                            android:text="@string/settings_profile_add_button"
                            android:textAllCaps="false"
                            android:textColor="@color/cp_cyan"
                            app:strokeColor="@color/cp_cyan" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/renameProfileButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:maxLines="1"
                            android:text="@string/settings_profile_rename_button"
                            android:textAllCaps="false"
                            android:textColor="@color/cp_cyan"
                            app:strokeColor="@color/cp_cyan" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/deleteProfileButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:maxLines="1"
                        android:text="@string/settings_profile_delete_button"
                        android:textAllCaps="false"
                        android:textColor="@color/cp_error"
                        app:strokeColor="@color/cp_error" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/importProfileButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:maxLines="1"
                        android:text="@string/settings_profile_import_button"
                        android:textAllCaps="false"
                        android:textColor="@color/cp_yellow"
                        app:strokeColor="@color/cp_yellow" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/wakeMethodCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_method_section"
                    android:textColor="@color/cp_yellow"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/settings_wake_method_hint"
                    app:boxBackgroundColor="@color/cp_surface_raised"
                    app:boxStrokeColor="@color/cp_yellow"
                    app:endIconMode="dropdown_menu"
                    app:hintTextColor="@color/cp_text_muted">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/wakeMethodInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/cp_text_primary"
                        android:textColorHint="@color/cp_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/wakeMethodDescriptionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/cp_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/relayRoutingCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_route_section"
                    android:textColor="@color/cp_yellow"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/settings_route_mode_hint"
                    app:boxBackgroundColor="@color/cp_surface_raised"
                    app:boxStrokeColor="@color/cp_yellow"
                    app:endIconMode="dropdown_menu"
                    app:hintTextColor="@color/cp_text_muted">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/routeModeInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/cp_text_primary"
                        android:textColorHint="@color/cp_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/settings_home_relay_hint"
                    app:boxBackgroundColor="@color/cp_surface_raised"
                    app:boxStrokeColor="@color/cp_cyan"
                    app:hintTextColor="@color/cp_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/homeRelayBaseUrlInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:textColor="@color/cp_text_primary"
                        android:textColorHint="@color/cp_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/settings_remote_relay_hint"
                    app:boxBackgroundColor="@color/cp_surface_raised"
                    app:boxStrokeColor="@color/cp_magenta"
                    app:hintTextColor="@color/cp_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/remoteRelayBaseUrlInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:textColor="@color/cp_text_primary"
                        android:textColorHint="@color/cp_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/settings_home_subnet_hint"
                    app:boxBackgroundColor="@color/cp_surface_raised"
                    app:boxStrokeColor="@color/cp_cyan"
                    app:hintTextColor="@color/cp_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/homeWifiSubnetInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/cp_text_primary"
                        android:textColorHint="@color/cp_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/settings_gateway_hint"
                    app:boxBackgroundColor="@color/cp_surface_raised"
                    app:boxStrokeColor="@color/cp_cyan"
                    app:hintTextColor="@color/cp_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/expectedGatewayInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/cp_text_primary"
                        android:textColorHint="@color/cp_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tokenLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/settings_token_hint"
                    app:boxBackgroundColor="@color/cp_surface_raised"
                    app:boxStrokeColor="@color/cp_magenta"
                    app:endIconMode="password_toggle"
                    app:hintTextColor="@color/cp_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/tokenInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:textColor="@color/cp_text_primary"
                        android:textColorHint="@color/cp_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/targetSettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_target_section"
                    android:textColor="@color/cp_yellow"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/settings_target_mac_hint"
                    app:boxBackgroundColor="@color/cp_surface_raised"
                    app:boxStrokeColor="@color/cp_cyan"
                    app:hintTextColor="@color/cp_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/targetMacInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/cp_text_primary"
                        android:textColorHint="@color/cp_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/settings_target_ip_hint"
                    app:boxBackgroundColor="@color/cp_surface_raised"
                    app:boxStrokeColor="@color/cp_cyan"
                    app:hintTextColor="@color/cp_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/targetIpInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/cp_text_primary"
                        android:textColorHint="@color/cp_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/settings_broadcast_hint"
                    app:boxBackgroundColor="@color/cp_surface_raised"
                    app:boxStrokeColor="@color/cp_cyan"
                    app:hintTextColor="@color/cp_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/broadcastIpInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/cp_text_primary"
                        android:textColorHint="@color/cp_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/wakeSettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_sleep_section"
                    android:textColor="@color/cp_yellow"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/settings_sleep_timeout_hint"
                        app:boxBackgroundColor="@color/cp_surface_raised"
                        app:boxStrokeColor="@color/cp_cyan"
                        app:hintTextColor="@color/cp_text_muted">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/sleepTimeoutInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLines="1"
                            android:textColor="@color/cp_text_primary"
                            android:textColorHint="@color/cp_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:hint="@string/settings_sleep_packets_hint"
                        app:boxBackgroundColor="@color/cp_surface_raised"
                        app:boxStrokeColor="@color/cp_cyan"
                        app:hintTextColor="@color/cp_text_muted">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/sleepPacketsInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLines="1"
                            android:textColor="@color/cp_text_primary"
                            android:textColorHint="@color/cp_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_sleep_note"
                    android:textColor="@color/cp_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/autoDetectLocalNetworkButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/local_setup_detect_button"
                    android:textAllCaps="false"
                    android:textColor="@color/cp_cyan"
                    app:strokeColor="@color/cp_cyan" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bootSettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_boot_section"
                    android:textColor="@color/cp_yellow"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/settings_boot_timeout_hint"
                        app:boxBackgroundColor="@color/cp_surface_raised"
                        app:boxStrokeColor="@color/cp_magenta"
                        app:hintTextColor="@color/cp_text_muted">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/remoteTimeoutInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLines="1"
                            android:textColor="@color/cp_text_primary"
                            android:textColorHint="@color/cp_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:hint="@string/settings_boot_packets_hint"
                        app:boxBackgroundColor="@color/cp_surface_raised"
                        app:boxStrokeColor="@color/cp_magenta"
                        app:hintTextColor="@color/cp_text_muted">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/remotePacketsInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLines="1"
                            android:textColor="@color/cp_text_primary"
                            android:textColorHint="@color/cp_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_boot_note"
                    android:textColor="@color/cp_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/helpCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/cp_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/cp_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_help_section"
                    android:textColor="@color/cp_yellow"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/settingsHelpBodyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_help_text"
                    android:textColor="@color/cp_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/settingsStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/cp_cyan"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearTokenButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_clear_token_button"
                android:textAllCaps="false"
                android:textColor="@color/cp_cyan"
                app:strokeColor="@color/cp_cyan" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveSettingsButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:backgroundTint="@color/cp_yellow"
                android:text="@string/settings_save_button"
                android:textAllCaps="false"
                android:textColor="@color/cp_background"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
